    "migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@cw/domain": "workspace:*",
    "@cw/ports": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@cw/application": "workspace:*",
    "@cw/test-kit": "workspace:*",
    "drizzle-kit": "^0.31.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "uuid": "^11.0.3",
    "vitest": "^2.1.8"
  },
  "license": "Apache-2.0"
}
