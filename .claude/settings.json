{
  "permissions": {
    "allow": [
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm build)",
      "Bash(pnpm -r test:*)",
      "Bash(pnpm -r --filter:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm exec biome check:*)",
      "Bash(pnpm exec biome format:*)",
      "Bash(pnpm exec tsc --noEmit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git grep:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(docker compose config:*)",
      "Bash(helm lint:*)",
      "Bash(helm template:*)",
      "Bash(helm dependency update infra/helm/contentworker:*)",
      "Bash(curl -s http://localhost:8787:*)"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-generated.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-check.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
