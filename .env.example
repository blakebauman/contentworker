# contentworker environment — copy to `.env` and fill in what you need.
#
#   cp .env.example .env
#
# `docker compose up` auto-loads `.env` from this directory. For the local stack
# only the AI section below is read by docker-compose.yml — Postgres/Redis URLs
# are wired internally. The rest documents the full 12-factor surface for when
# you run services directly (pnpm --filter @cw/api start, the worker, etc.).

# ─── AI: entry generation (Generate with AI) ─────────────────────────────────
# Set a key to use the real model; leave unset and the API falls back to a dev
# stub that returns placeholder field values (offline, no cost).
ANTHROPIC_API_KEY=
# Provider for generation/enrichment: anthropic (default) | azure-openai
AI_PROVIDER=anthropic

# Azure OpenAI — only if AI_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=

# ─── Embeddings (RAG / semantic search) ──────────────────────────────────────
# Provider: unset → local deterministic embeddings (dev) | azure-openai
EMBEDDINGS_PROVIDER=
EMBEDDINGS_DIM=1536

# ─── Datastores ──────────────────────────────────────────────────────────────
# docker compose sets these internally. Set them here only when running a
# service directly against your own Postgres/Redis. Unset → seeded in-memory.
DATABASE_URL=
REDIS_URL=

# ─── Blob storage (assets) ───────────────────────────────────────────────────
# BLOB_BUCKET set → S3/MinIO; unset → in-memory fake (dev).
BLOB_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BLOB_ENDPOINT=
BLOB_FORCE_PATH_STYLE=
BLOB_PUBLIC_BASE_URL=

# ─── API service ─────────────────────────────────────────────────────────────
PORT=8787
# Which API modules mount: all | management | delivery | preview
ROLE=all
# Bootstrap a dev space + keys + demo content on a real database (idempotent).
SEED_DEV=true
SEED_SPACE_ID=space-1
SEED_ENV_ID=main
SEED_DEFAULT_LOCALE=en-US
SEED_LOCALES=en-US,de-DE
# Dev tokens (override in production). Defaults: dev-cma-key / dev-cda-key /
# dev-cpa-key / dev-admin-token.
CMA_KEY=
CDA_KEY=
CPA_KEY=
ADMIN_TOKEN=

# ─── Worker (outbox relay + agents) ──────────────────────────────────────────
RELAY_INTERVAL_MS=1000
# On-publish agents: enrich (generate empty fields) and moderate (classify +
# hold when flagged), plus auto-apply vs. human-in-the-loop review for enrich.
AGENTS_ENRICH=false
AGENTS_MODERATE=false
AGENTS_AUTO_APPLY=false
# Temporal (durable agent runtime); unset → in-process runtime.
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=

# ─── Admin SPA (dev) ─────────────────────────────────────────────────────────
# API target the Vite proxy forwards to (same-origin). Port pinned by the e2e/
# docker harness. VITE_USE_POLLING is set by docker for HMR over the bind mount.
CW_API_URL=http://localhost:8787
CW_ADMIN_PORT=
VITE_USE_POLLING=
# Optional SSO: admin-bff OIDC login URL (shows Sign in with SSO on /connect).
VITE_SSO_LOGIN_URL=

# ─── Admin BFF (OIDC SSO) ────────────────────────────────────────────────────
# Set all four OIDC_* vars to enable SSO via apps/admin-bff (compose exposes :8790).
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8790/auth/callback
OIDC_GROUP_ROLE_MAP={}

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
